# Feature flags
PUBLIC_ALLOW_REGISTRATION="false"

# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

ORIGIN=""

# Better Auth
# Full production URL with no trailing slash (e.g. https://your-app.vercel.app)
# Must match the actual request origin exactly — wrong value causes auth routes to 404
BETTER_AUTH_URL=""
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
