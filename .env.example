# Feature flags
PUBLIC_ALLOW_REGISTRATION="false"

# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Google Analytics — measurement ID from analytics.google.com
PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Cloudflare Turnstile — create a site at dash.cloudflare.com → Turnstile
PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
